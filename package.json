{
  "name": "td-languages-lib",
  "version": "1.0.0",
  "description": "TypeScript utilities and language metadata (names, abbreviations, locales, and text orientation).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "languages",
    "language-abbreviations",
    "internationalization",
    "regionalization",
    "localization",
    "locale",
    "language-selector",
    "typescript",
    "constants",
    "language-list"
  ],
  "author": "Jarosław Tusiński",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "td-languages-abbreviations": "^1.0.1",
    "td-languages-locales": "^1.0.2",
    "td-languages-names": "^1.0.2"
  }
}
